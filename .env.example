# RPC / explorer
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# Deploy script
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
PROTOCOL_ADMIN=0xYOUR_PROTOCOL_ADMIN
TREASURY=0xYOUR_TREASURY
GUARDIAN=0xYOUR_GUARDIAN
EVALUATOR=0xYOUR_EVALUATOR
USDC_ADDRESS=
REVOKE_DEPLOYER_ADMIN=true

# Optional deploy overrides
MAX_ADVANCE_RATE=9000
MIN_INTEREST_RATE=500
MAX_CREDIT_DURATION=15552000
PROTOCOL_FEE_RATE=1000
DEFAULT_GRACE_PERIOD=604800
SELLER_STAKE_RATE=2000
MIN_TOKEN_HOLDING_FOR_PERKS=1000000000000000000000
TOKEN_HOLDER_APR_DISCOUNT_BPS=300
TOKEN_HOLDER_GRACE_BONUS=0
GOOD_CREDIT_SCORE_THRESHOLD=70
GOOD_CREDIT_EXTRA_GRACE=172800

# Seed script
# ADMIN_PRIVATE_KEY should control the deployed protocol admin / HKP minter.
ADMIN_PRIVATE_KEY=0xYOUR_PROTOCOL_ADMIN_PRIVATE_KEY
SEED_EVALUATOR_PRIVATE_KEY=0xYOUR_EVALUATOR_PRIVATE_KEY
SEED_LP_PRIVATE_KEY=0xYOUR_LP_PRIVATE_KEY
SEED_BORROWER_PRIVATE_KEY=0xYOUR_BORROWER_PRIVATE_KEY
SEED_PAYER=0x000000000000000000000000000000000000BEEF

# Copy these from deployments/sepolia.json after deploy
SEED_PROTOCOL_CONFIG=0xYOUR_PROTOCOL_CONFIG
SEED_RECEIVABLE_NFT=0xYOUR_RECEIVABLE_NFT
SEED_EVALUATION_AGENT=0xYOUR_EVALUATION_AGENT
SEED_LIQUIDITY_POOL=0xYOUR_LIQUIDITY_POOL
SEED_CREDIT_FACILITY=0xYOUR_CREDIT_FACILITY
SEED_HKP_TOKEN=0xYOUR_HKP_TOKEN
SEED_USDC=0xYOUR_USDC

# If you deployed MockUSDC, keep true. If you use a real Sepolia USDC, set false
# and pre-fund the LP / borrower addresses yourself.
SEED_MINT_TEST_USDC=true
SEED_MINT_TEST_HKP=true
SEED_REPAID_LINE=true

# Raw token units
SEED_LP_USDC_AMOUNT=250000000000
SEED_BORROWER_USDC_AMOUNT=100000000000
SEED_BORROWER_HKP_AMOUNT=2000000000000000000000
SEED_LP_DEPOSIT_AMOUNT=200000000000
SEED_BORROWER_MAX_CREDIT_LIMIT=200000000000
SEED_BORROWER_INTEREST_RATE=1500
SEED_BORROWER_ADVANCE_RATE=6000
SEED_ACTIVE_RECEIVABLE_FACE_AMOUNT=100000000000
SEED_ACTIVE_DRAWDOWN_AMOUNT=60000000000
SEED_ACTIVE_RECEIVABLE_DURATION=5184000
SEED_APPROVED_RECEIVABLE_FACE_AMOUNT=80000000000
SEED_APPROVED_RECEIVABLE_DURATION=6480000
SEED_REPAID_RECEIVABLE_FACE_AMOUNT=40000000000
SEED_REPAID_DRAWDOWN_AMOUNT=20000000000
SEED_REPAID_RECEIVABLE_DURATION=2592000
